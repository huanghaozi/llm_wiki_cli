{
  "name": "llm-wiki",
  "private": true,
  "version": "0.4.13",
  "description": "LLM Wiki CLI — terminal-based personal knowledge base with ingest, RAG chat, hybrid search, and graph analysis",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --build --pretty",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "test": "npm run test:mocks && npm run test:llm",
    "test:mocks": "vitest run --exclude='**/*.real-llm.test.ts'",
    "test:llm": "vitest run real-llm --no-file-parallelism --reporter=verbose",
    "tauri": "tauri",
    "cli:dev": "bun run cli/index.ts",
    "cli:build": "bun build --compile cli/index.ts --outfile llm-wiki",
    "cli:build:win": "bun build --compile cli/index.ts --outfile llm-wiki.exe",
    "test:cli": "vitest run --config vitest.cli.config.ts",
    "test:cli:coverage": "vitest run --config vitest.cli.config.ts --coverage",
    "test:cli:watch": "vitest --config vitest.cli.config.ts",
    "native:build": "powershell -ExecutionPolicy Bypass -File scripts/build-native.ps1",
    "native:test": "cargo test --manifest-path native/Cargo.toml"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@inquirer/prompts": "^8.4.3",
    "@lancedb/lancedb": "^0.29.0",
    "@milkdown/kit": "^7.20.0",
    "@milkdown/plugin-math": "^7.5.9",
    "@milkdown/react": "^7.20.0",
    "@milkdown/theme-nord": "^7.20.0",
    "@react-sigma/core": "^5.0.6",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@types/js-yaml": "^4.0.9",
    "@types/pdf-parse": "^1.1.5",
    "apache-arrow": "18.1.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-layout-forceatlas2": "^0.10.1",
    "i18next": "^26.0.3",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.45",
    "lucide-react": "^1.7.0",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "ora": "^9.4.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.2",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.9.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shadcn": "^4.1.2",
    "sigma": "^3.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "fast-check": "^4.7.0",
    "typescript": "^5.7.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.4"
  }
}
